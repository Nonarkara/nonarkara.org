  <!-- Service worker — manual nuke path: /?reset -->
  <script>
    if (location.search.indexOf('reset') !== -1) {
      (async () => {
        try {
          const ws = await navigator.serviceWorker.getRegistrations();
          await Promise.all(ws.map(r => r.unregister()));
          const ks = await caches.keys();
          await Promise.all(ks.map(k => caches.delete(k)));
        } catch (_) {}
        location.replace('/');
      })();
    }
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').then(reg => {
          try { reg.update(); } catch (_) {}
        }).catch(() => {});
        if (navigator.serviceWorker.controller) {
          let __refreshing = false;
          navigator.serviceWorker.addEventListener('controllerchange', () => {
            if (__refreshing) return;
            __refreshing = true;
            location.reload();
          });
        }
      });
    }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;700&amp;family=JetBrains+Mono:wght@300;400&amp;family=Josefin+Sans:wght@300;700&amp;family=Noto+Sans+SC:wght@300;700&amp;display=swap" rel="stylesheet"/>

  <!-- External CSS -->
  <link rel="stylesheet" href="styles.css"/>

  <script src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js"></script>
  <script type="importmap">
  {
    "imports": {
      "three": "./vendor-three-0.160.0.js"
    }
  }
  </script>
<script src="https://www.kimi.com/sdk-seed.js" defer=""></script></head>
<body data-lang="en">

  <!-- Boot screen -->
  <div id="boot" aria-hidden="true">
    <div class="boot-logo">N<span class="boot-o">O</span>N</div>
    <div class="boot-sub" id="boot-sub">A WINDOW TO THE MIND</div>
  </div>

  <!-- 3D Room canvas -->
  <div id="canvas-root"></div>

  <!-- Overlay UI -->
  <div class="overlay" id="overlay">
    <div class="brand" id="brand" role="button" tabindex="0" aria-label="NON">NON</div>
    <div class="caption" id="caption">a window to the mind</div>
    <div class="hint" id="hint">tap any screen or object · drag to look around</div>
    <div class="meta" id="meta">
      <a href="/cdn-cgi/l/email-protection#4f2c20213b2e2c3b0f2120212e3d242e3d2e61203d28" id="contact-link">contact</a>
      <span>·</span>
      <a href="https://github.com/Nonarkara" target="_blank" rel="noopener">github</a>
    </div>
    <div class="lang" id="lang">
      <button data-l="en" class="on">EN</button>
      <span class="sep">·</span>
      <button data-l="th">ไทย</button>
      <span class="sep">·</span>
      <button data-l="zh">中文</button>
    </div>
  </div>

  <div class="tip" id="tip"><span id="tip-text"></span><span class="url" id="tip-url"></span></div>
  <div class="veil" id="veil"></div>

  <!-- Modal container -->
  <div class="modal" id="modal"><div class="modal-bg" id="modal-bg"></div><div class="modal-card" id="modal-card"></div></div>

  <!-- Plan view -->
  <div id="plan" aria-hidden="true"></div>

  <!-- Drawer -->
  <div class="drawer" id="drawer"><div class="drawer-bg" id="drawer-bg"></div><div class="drawer-panel" id="drawer-panel"><div class="drawer-handle"></div><div id="drawer-body"></div></div></div>

  <!-- Menu button -->
  <button class="menu-btn" id="menu-btn">MENU</button>

  <!-- View toggle -->
  <button class="view-toggle" id="view-toggle">PLAN</button>

  <!-- Pomodoro -->
  <div class="pomodoro" id="pomodoro"></div>

  <!-- Portrait gallery -->
  <div class="pga" id="pga"></div>

  <!-- FRAME museum -->
  <div class="frame" id="frame"></div>

  <!-- Konami haiku -->
  <div class="konami" id="konami"></div>

  <!-- WebGL fallback message -->
  <div class="webgl-fallback" id="webgl-fallback">
    <div class="mark">N<span class="boot-o">O</span>N</div>
    <div class="msg">Your browser doesn&#39;t support WebGL, which powers the 3D room.<br/><br/>No problem — the plan view has everything.</div>
    <button class="action" id="fallback-btn">CONTINUE TO PLAN VIEW</button>
  </div>

  <!-- Main app module -->
  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script type="module" src="app.js"></script>



</body></html>